{
  "name": "crm-app",
  "version": "1.0.0",
  "description": "Construction CRM Application",
  "main": "index.js",
  "scripts": {
    "start": "node crm-backend/server.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon crm-backend/server.js",
    "client": "cd crm-frontend && npm start",
    "build": "cd crm-frontend && npm run build",
    "install-all": "npm install && cd crm-frontend && npm install"
  },
  "dependencies": {
    "@mui/icons-material": "^7.2.0",
    "bcryptjs": "^3.0.2",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.0",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "jwt-decode": "^4.0.0",
    "mongoose": "^8.16.4",
    "morgan": "^1.10.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.10"
  }
}